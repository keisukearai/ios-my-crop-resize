default_platform(:ios)

platform :ios do

  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
    )
  end

  # メタデータのみアップロード
  lane :upload_metadata do
    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.keisukearai.MyCropResize",
      app_version: "1.0",
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  # スクリーンショットのみアップロード
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.keisukearai.MyCropResize",
      app_version: "1.0",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  # TestFlight にアップロード（Xcode 自動署名を使用）
  lane :beta do
    update_code_signing_settings(
      use_automatic_signing: true,
      path: "MyCropResize.xcodeproj",
      team_id: "HFZSU3MJLR",
    )
    increment_build_number(xcodeproj: "MyCropResize.xcodeproj")
    build_app(
      scheme: "MyCropResize",
      export_method: "app-store",
      export_xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "HFZSU3MJLR",
      },
    )
    upload_to_testflight(api_key: api_key)
  end

  # App Store に申請（Xcode 自動署名を使用）
  lane :release do
    update_code_signing_settings(
      use_automatic_signing: true,
      path: "MyCropResize.xcodeproj",
      team_id: "HFZSU3MJLR",
    )
    increment_build_number(xcodeproj: "MyCropResize.xcodeproj")
    build_app(
      scheme: "MyCropResize",
      export_method: "app-store",
      export_xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "HFZSU3MJLR",
      },
    )
    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.keisukearai.MyCropResize",
      app_version: "1.0",
      submit_for_review: true,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

end
